# Server
PORT=5000
NODE_ENV=development

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-client-email@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# OpenWeatherMap (free tier)
OPENWEATHER_API_KEY=your-openweather-api-key

# AQICN (Air Quality)
AQI_API_KEY=your-aqicn-api-key

# News API
NEWS_API_KEY=your-newsapi-key

# Razorpay (for payouts)
RAZORPAY_KEY_ID=your-razorpay-key
RAZORPAY_KEY_SECRET=your-razorpay-secret

# Disruption scheduler (cron syntax) — runs the auto-detect + auto-claim pipeline
DISRUPTION_SCHEDULE=*/15 * * * *
# Set to "true" to disable the scheduler (e.g. for tests or local dev)
DISABLE_DISRUPTION_SCHEDULER=false

# SMTP (Gmail via Nodemailer — use a Google App Password, not your real password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM_NAME=Earnly
SMTP_FROM_EMAIL=your-gmail@gmail.com
